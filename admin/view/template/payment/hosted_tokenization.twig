{{ header }}{{ column_left }}
<div id="content" class="payment-worldline">
	<div class="page-header">
		<div class="container-fluid">
			<div class="float-end">
				<a href="{{ sign_up }}" target="_blank" class="btn btn-primary">{{ button_sign_up }}</a>
				<a href="{{ contact_us }}" target="_blank" class="btn btn-primary">{{ button_contact_us }}</a>
				<button type="submit" form="form-payment" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary button-save"><i class="fas fa-save"></i></button>
				<a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_back }}" class="btn btn-light"><i class="fas fa-reply"></i></a>
			</div>
			<h1>{{ heading_title }}</h1>
			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
				<li class="breadcrumb-item"><a href="{{ breadcrumb['href'] }}">{{ breadcrumb['text'] }}</a></li>
				{% endfor %}
			</ul>
		</div>
	</div>
	<div class="container-fluid">
		{% if text_version %}
		<div class="alert alert-info"><i class="fas fa-info-circle"></i> {{ text_version }}</div>
		{% endif %}
		<div class="card">
			<div class="card-header"><i class="fas fa-pencil-alt"></i> {{ text_edit }}</div>
			<div class="card-body">
				<ul class="nav nav-tabs">
					<li class="nav-item"><a href="{{ href_account }}" class="nav-link"><i class="fas fa-user"></i> {{ text_tab_account }}</a></li>
					<li class="nav-item"><a href="{{ href_advanced }}" class="nav-link"><i class="fas fa-cogs"></i> {{ text_tab_advanced }}</a></li>
					<li class="nav-item"><a href="{{ href_hosted_checkout }}" class="nav-link"><i class="fas fa-list-alt"></i> {{ text_tab_hosted_checkout }}</a></li>
					<li class="nav-item"><a href="{{ href_hosted_tokenization }}" class="nav-link active"><i class="fas fa-credit-card"></i> {{ text_tab_hosted_tokenization }}</a></li>
					<li class="nav-item"><a href="{{ href_order_status }}" class="nav-link"><i class="fas fa-shopping-cart"></i> {{ text_tab_order_status }}</a></li>
					<li class="nav-item"><a href="{{ href_transaction }}" class="nav-link"><i class="fas fa-money-bill"></i> {{ text_tab_transaction }}</a></li>
					<li class="nav-item"><a href="{{ href_suggest }}" class="nav-link"><i class="far fa-envelope"></i> {{ text_tab_suggest }}</a></li>
				</ul>
				<div class="tab-content">
					<form action="{{ save }}" method="post" id="form-payment" data-oc-toggle="ajax">
						<div class="row mb-3">
							<label class="col-sm-2 col-form-label" for="input-status">{{ entry_status }}</label>
							<div class="col-sm-10">
								<div class="form-check form-switch form-switch-lg">
									<input type="hidden" name="payment_worldline_setting[hosted_tokenization][status]" value="0"/>
									<input type="checkbox" name="payment_worldline_setting[hosted_tokenization][status]" value="1" id="input-status" class="form-check-input"{% if setting['hosted_tokenization']['status'] %} checked{% endif %}/>
								</div>
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-2 col-form-label" for="input-title">{{ entry_title }}</label>
							<div class="col-sm-10">
								{% for language in languages %}
								<div class="input-group">
									<span class="input-group-text" style="min-width: 65px"><img src="language/{{ language['code'] }}/{{ language['code'] }}.png" title="{{ language['name'] }}" /> {{ language['language_code'] }}</span>
									<input type="text" name="payment_worldline_setting[hosted_tokenization][title][{{ language['language_id'] }}]" value="{% if setting['hosted_tokenization']['title'][language['language_id']] %}{{ setting['hosted_tokenization']['title'][language['language_id']] }}{% endif %}" placeholder="{{ entry_title }}" id="input-title-{{ language['language_id'] }}" class="form-control" />
								</div>
								{% endfor %}
							</div>
                        </div>
						<div class="row mb-3">
							<label class="col-sm-2 col-form-label" for="input-button-title">{{ entry_button_title }}</label>
							<div class="col-sm-10">
								{% for language in languages %}
								<div class="input-group">
									<span class="input-group-text" style="min-width: 65px"><img src="language/{{ language['code'] }}/{{ language['code'] }}.png" title="{{ language['name'] }}" /> {{ language['language_code'] }}</span>
									<input type="text" name="payment_worldline_setting[hosted_tokenization][button_title][{{ language['language_id'] }}]" value="{% if setting['hosted_tokenization']['button_title'][language['language_id']] %}{{ setting['hosted_tokenization']['button_title'][language['language_id']] }}{% endif %}" placeholder="{{ entry_button_title }}" id="input-button-title-{{ language['language_id'] }}" class="form-control" />
								</div>
								{% endfor %}
							</div>
                        </div>
						<div class="row mb-3">
							<label class="col-sm-2 col-form-label" for="input-group-cards">{{ entry_group_cards }}</label>
							<div class="col-sm-10">
								<div class="input-group">
									<select name="payment_worldline_setting[hosted_tokenization][group_cards]" id="input-group-cards" class="form-select">
										{% if setting['hosted_tokenization']['group_cards'] %}
										<option value="1" selected="selected">{{ text_enabled }}</option>
										<option value="0">{{ text_disabled }}</option>
										{% else %}
										<option value="1">{{ text_enabled }}</option>
										<option value="0" selected="selected">{{ text_disabled }}</option>
										{% endif %}
									</select>
								</div>
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-2 col-form-label" for="input-template"><span data-bs-toggle="tooltip" title="{{ help_template }}">{{ entry_template }}</span></label>
							<div class="col-sm-10">
								<div class="input-group">
									<input type="text" name="payment_worldline_setting[hosted_tokenization][template]" value="{{ setting['hosted_tokenization']['template'] }}" placeholder="{{ entry_template }}" id="input-template" class="form-control" />
								</div>
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-2 col-form-label" for="input-wero-capture-trigger">{{ entry_wero_capture_trigger }}</label>
							<div class="col-sm-10">
								<div class="input-group">
									<select name="payment_worldline_setting[hosted_tokenization][wero_capture_trigger]" id="input-wero-capture-trigger" class="form-select">
										{% for wero_capture_trigger in setting['wero_capture_trigger'] %}
										{% if wero_capture_trigger['code'] == setting['hosted_tokenization']['wero_capture_trigger'] %}
										<option value="{{ wero_capture_trigger['code'] }}" selected="selected">{{ attribute(_context, wero_capture_trigger['name']) }}</option>
										{% else %}
										<option value="{{ wero_capture_trigger['code'] }}">{{ attribute(_context, wero_capture_trigger['name']) }}</option>
										{% endif %}
										{% endfor %}
									</select>
								</div>
							</div>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>
{{ footer }}