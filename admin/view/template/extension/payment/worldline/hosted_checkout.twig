{{ header }}{{ column_left }}
<div id="content" class="payment-worldline">
	<div class="page-header">
		<div class="container-fluid">
			<div class="pull-right">
				<a href="{{ sign_up }}" target="_blank" class="btn btn-primary">{{ button_sign_up }}</a>
				<a href="{{ contact_us }}" target="_blank" class="btn btn-primary">{{ button_contact_us }}</a>
				<button type="button" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary button-save"><i class="fa fa-save"></i></button>
				<a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
			</div>
			<h1>{{ heading_title }}</h1>
			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
				<li><a href="{{ breadcrumb['href'] }}">{{ breadcrumb['text'] }}</a></li>
				{% endfor %}
			</ul>
		</div>
	</div>
	<div class="container-fluid">
		{% if error_warning %}
		<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
			<button type="button" class="close" data-dismiss="alert">&times;</button>
		</div>
		{% endif %}
		{% if text_version %}
		<div class="alert alert-info"><i class="fa fa-info-circle"></i> {{ text_version }}</div>
		{% endif %}
		<div class="panel panel-default">
			<div class="panel-heading">
				<h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
			</div>
			<div class="panel-body">
				<ul class="nav nav-tabs">
					<li class="nav-tab"><a href="{{ href_account }}" class="tab"><i class="fa fa-user"></i> {{ text_tab_account }}</a></li>
					<li class="nav-tab"><a href="{{ href_advanced }}" class="tab"><i class="fa fa-cogs"></i> {{ text_tab_advanced }}</a></li>
					<li class="nav-tab active"><a href="{{ href_hosted_checkout }}" class="tab"><i class="fa fa-list-alt"></i> {{ text_tab_hosted_checkout }}</a></li>
					<li class="nav-tab"><a href="{{ href_hosted_tokenization }}" class="tab"><i class="fa fa-credit-card"></i> {{ text_tab_hosted_tokenization }}</a></li>
					<li class="nav-tab"><a href="{{ href_order_status }}" class="tab"><i class="fa fa-shopping-cart"></i> {{ text_tab_order_status }}</a></li>
					<li class="nav-tab"><a href="{{ href_transaction }}" class="tab"><i class="fa fa-money"></i> {{ text_tab_transaction }}</a></li>
					<li class="nav-tab"><a href="{{ href_suggest }}" class="tab"><i class="fa fa-envelope-o"></i> {{ text_tab_suggest }}</a></li>
				</ul>
				<div class="tab-content">
					<form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-payment" class="form-horizontal">
						<div class="form-group">
							<label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
							<div class="col-sm-10">
								<select name="payment_worldline_setting[hosted_checkout][status]" id="input-status" class="form-control">
									{% if setting['hosted_checkout']['status'] %}
									<option value="1" selected="selected">{{ text_enabled }}</option>
									<option value="0">{{ text_disabled }}</option>
									{% else %}
									<option value="1">{{ text_enabled }}</option>
									<option value="0" selected="selected">{{ text_disabled }}</option>
									{% endif %}
								</select>
							</div>
						</div>
						<div class="form-group">
							<label class="col-sm-2 control-label" for="input-title">{{ entry_title }}</label>
							<div class="col-sm-10">
								{% for language in languages %}
								<div class="input-group">
									<span class="input-group-addon" style="min-width: 65px"><img src="language/{{ language['code'] }}/{{ language['code'] }}.png" title="{{ language['name'] }}" /> {{ language['language_code'] }}</span>
									<input type="text" name="payment_worldline_setting[hosted_checkout][title][{{ language['language_id'] }}]" value="{% if setting['hosted_checkout']['title'][language['language_id']] %}{{ setting['hosted_checkout']['title'][language['language_id']] }}{% endif %}" placeholder="{{ entry_title }}" id="input-title-{{ language['language_id'] }}" class="form-control" />
								</div>
								{% endfor %}
							</div>
                        </div>
						<div class="form-group">
							<label class="col-sm-2 control-label" for="input-button-title">{{ entry_button_title }}</label>
							<div class="col-sm-10">
								{% for language in languages %}
								<div class="input-group">
									<span class="input-group-addon" style="min-width: 65px"><img src="language/{{ language['code'] }}/{{ language['code'] }}.png" title="{{ language['name'] }}" /> {{ language['language_code'] }}</span>
									<input type="text" name="payment_worldline_setting[hosted_checkout][button_title][{{ language['language_id'] }}]" value="{% if setting['hosted_checkout']['button_title'][language['language_id']] %}{{ setting['hosted_checkout']['button_title'][language['language_id']] }}{% endif %}" placeholder="{{ entry_button_title }}" id="input-button-title-{{ language['language_id'] }}" class="form-control" />
								</div>
								{% endfor %}
							</div>
                        </div>
						<div class="form-group">
							<label class="col-sm-2 control-label" for="input-group-cards">{{ entry_group_cards }}</label>
							<div class="col-sm-10">
								<select name="payment_worldline_setting[hosted_checkout][group_cards]" id="input-group-cards" class="form-control">
									{% if setting['hosted_checkout']['group_cards'] %}
									<option value="1" selected="selected">{{ text_enabled }}</option>
									<option value="0">{{ text_disabled }}</option>
									{% else %}
									<option value="1">{{ text_enabled }}</option>
									<option value="0" selected="selected">{{ text_disabled }}</option>
									{% endif %}
								</select>
							</div>
						</div>
						<div class="form-group">
							<label class="col-sm-2 control-label" for="input-template"><span data-toggle="tooltip" title="{{ help_template }}">{{ entry_template }}</span></label>
							<div class="col-sm-10">
								<input type="text" name="payment_worldline_setting[hosted_checkout][template]" value="{{ setting['hosted_checkout']['template'] }}" placeholder="{{ entry_template }}" id="input-template" class="form-control" />
							</div>
						</div>
						<div class="form-group">
							<label class="col-sm-2 control-label" for="input-wero-capture-trigger">{{ entry_wero_capture_trigger }}</label>
							<div class="col-sm-10">
								<select name="payment_worldline_setting[hosted_checkout][wero_capture_trigger]" id="input-wero-capture-trigger" class="form-control">
									{% for wero_capture_trigger in setting['wero_capture_trigger'] %}
									{% if wero_capture_trigger['code'] == setting['hosted_checkout']['wero_capture_trigger'] %}
									<option value="{{ wero_capture_trigger['code'] }}" selected="selected">{{ attribute(_context, wero_capture_trigger['name']) }}</option>
									{% else %}
									<option value="{{ wero_capture_trigger['code'] }}">{{ attribute(_context, wero_capture_trigger['name']) }}</option>
									{% endif %}
									{% endfor %}
								</select>
							</div>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>
<script type="text/javascript">

$('.payment-worldline').on('click', '.button-save', function() {
    $.ajax({
		type: 'post',
		url: $('#form-payment').attr('action'),
		data: $('#form-payment').serialize(),
		dataType: 'json',
		success: function(json) {
			$('.payment-worldline .alert-dismissible, .payment-worldline .text-danger').remove();
			$('.payment-worldline .form-group').removeClass('has-error');
						
			if (json['error']) {
				if (json['error']['warning']) {
					$('.payment-worldline > .container-fluid').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json['error']['warning'] + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
					
					$('html, body').animate({scrollTop: $('.payment-worldline > .container-fluid .alert-danger').offset().top}, 'slow');
				}				
				
				for (i in json['error']) {
					var element = $('#input-' + i.replaceAll('_', '-'));

					if (element.parent().hasClass('input-group')) {
                   		$(element).parent().after('<div class="text-danger">' + json['error'][i] + '</div>');
					} else {
						$(element).after('<div class="text-danger">' + json['error'][i] + '</div>');
					}
				}				
				
				$('.payment-worldline .text-danger').parentsUntil('.form-group').parent().addClass('has-error');
			}
			
			if (json['success']) {
				$('.payment-worldline > .container-fluid').prepend('<div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> ' + json['success'] + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
				
				$('html, body').animate({scrollTop: $('.payment-worldline > .container-fluid .alert-success').offset().top}, 'slow');
			}
		},
		error: function(xhr, ajaxOptions, thrownError) {
			console.log(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
    });  
});

</script>
{{ footer }}